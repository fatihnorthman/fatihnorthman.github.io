[
  {{- range $index, $page := .Site.RegularPages -}}
  {{- if $index -}}, {{ end -}}
  {
    "title": {{ .Title | jsonify }},
    "permalink": {{ .Permalink | jsonify }},
    "date": {{ .Date.Format "02.01.2006" | jsonify }},
    "tags": {{ .Params.tags | jsonify }},
    "content": {{ .Plain | jsonify }}
  }
  {{- end -}}
]
